# ── Run outputs ──────────────────────────────────────────────
# Ignore the raw per-run dumps (hundreds of MB of CSV/log/json), but KEEP the
# published charts and the small headline summary files (re-included via ! below).
results/**
!results/eks/
!results/eks/matrix_100k_30min/
!results/eks/matrix_100k_30min/SUMMARY.txt
!results/eks/matrix_100k_30min/MATRIX_100k_summary.txt
!results/local/
!results/local/MATRIX_local_summary.txt

# The 8 published charts ARE committed (blog + README reference them); any other
# png (stale/experimental) is not.
docs/charts/*
!docs/charts/lag_append.png
!docs/charts/lag_upsert.png
!docs/charts/throughput.png
!docs/charts/memory.png
!docs/charts/commit_interval.png
!docs/charts/file_size.png
!docs/charts/batch_breakdown.png
!docs/charts/local_vs_eks.png
!docs/charts/summary_card.png

# ── Build artifacts ──────────────────────────────────────────
**/target/
**/.gradle/
**/build/
*.jar
# Vendored Spark jars (116 MB — regenerate with spark/fetch-jars.sh)
spark/jars/

# ── Secrets / local env / account-specific overrides ─────────
.env.local
eks/cluster.local.yaml
eks/kubeconfig
eks/.env.eks
eks/.registry.env

# Terraform (if used)
eks/terraform/.terraform/
eks/terraform/*.tfstate*
eks/terraform/.terraform.lock.hcl

# ── Python / IDE / OS ────────────────────────────────────────
__pycache__/
*.pyc
.venv/
.idea/
.vscode/
.DS_Store
