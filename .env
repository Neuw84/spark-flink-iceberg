# ─────────────────────────────────────────────────────────────
# spark-flink-iceberg benchmark — shared configuration
# Sourced by docker-compose, bench/*.sh, and the producer.
# ─────────────────────────────────────────────────────────────

# --- Versions (kept in lock-step across engines) ---
FLINK_VERSION=2.2.0
SPARK_VERSION=4.1.2
ICEBERG_VERSION=1.11.0
# Apache Kafka (KRaft) locally — same distribution Strimzi runs on EKS, matching
# the prior spark-rtm-vs-flink benchmark. Wire-identical to the EKS broker.
KAFKA_IMAGE=apache/kafka:4.1.0
JAVA_VERSION=17
SCALA_BINARY=2.13

# --- Kafka / source ---
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_BOOTSTRAP_HOST=localhost:29092
SOURCE_TOPIC=events
KAFKA_PARTITIONS=12

# --- Object store (MinIO stands in for S3 locally) ---
S3_ENDPOINT=http://minio:9000
S3_ENDPOINT_HOST=http://localhost:9000
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1
WAREHOUSE_BUCKET=warehouse

# --- Iceberg REST catalog ---
CATALOG_URI=http://iceberg-rest:8181
CATALOG_NAME=demo
ICEBERG_DB=streaming
ICEBERG_TABLE=events

# --- Workload knobs ---
# Target ingest rate in records/sec and the run duration used by bench scripts.
TARGET_RATE=100000
RUN_SECONDS=600
# Approx payload size per record ~ 500 bytes -> ~50 MB/s at 100k rps
PAYLOAD_BYTES=500

# --- Iceberg write behavior (overridable per run) ---
# distribution mode: none | hash | range
WRITE_DISTRIBUTION_MODE=hash
# format version: 2 (equality deletes) | 3 (deletion vectors)
TABLE_FORMAT_VERSION=2
# append | upsert
WRITE_MODE=append
# checkpoint / commit interval in ms (Flink) — Spark uses a matching trigger
CHECKPOINT_INTERVAL_MS=30000

# Host-side endpoints for bench tooling (pyiceberg on the host, not in-container)
CATALOG_URI_HOST=http://localhost:8181
