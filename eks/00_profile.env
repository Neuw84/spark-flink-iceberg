# ─────────────────────────────────────────────────────────────
# Dedicated environment for THIS benchmark.
#
# Pins region + a DEDICATED kubeconfig so kubectl never touches your shared
# ~/.kube/config, and every script targets only this benchmark's cluster.
#
# BEFORE RUNNING: set ACCOUNT_EXPECTED to your AWS account id (the scripts refuse
# to act against any other account — a guard against running in the wrong place).
# Credentials come from the CLI's default chain; set AWS_PROFILE below to use a
# named profile.
#
# Region note — us-east-1 everywhere: co-locating cluster + warehouse in us-east-1
# means the IRSA/pod-identity webhook injects AWS_REGION=us-east-1, which matches
# the S3 bucket. That's the config that avoids Iceberg S3FileIO's cross-region 301
# under IRSA (a regional bucket + webhook-injected wrong region 301s).
# ─────────────────────────────────────────────────────────────
# Only export AWS_PROFILE if the caller set a non-empty one; an empty AWS_PROFILE
# breaks the default credential chain.
[ -n "${AWS_PROFILE:-}" ] && export AWS_PROFILE
export AWS_REGION=us-east-1
export AWS_DEFAULT_REGION=us-east-1

export CLUSTER=sfi-iceberg-bench
export ACCOUNT_EXPECTED="${ACCOUNT_EXPECTED:-<YOUR_ACCOUNT_ID>}"   # guard: scripts refuse to run elsewhere
# Dedicated kubeconfig lives in this dir — NEVER ~/.kube/config.
export KUBECONFIG="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/kubeconfig"

_sfi_whoami() { aws sts get-caller-identity --query 'Account' --output text 2>/dev/null; }

# Guardrail every script calls before doing anything: refuse to act on the wrong account.
_sfi_guard() {
  local acct; acct=$(_sfi_whoami)
  if [ "$ACCOUNT_EXPECTED" = "<YOUR_ACCOUNT_ID>" ]; then
    echo "REFUSING: set ACCOUNT_EXPECTED in eks/00_profile.env to your AWS account id first." >&2
    return 1
  fi
  if [ "$acct" != "$ACCOUNT_EXPECTED" ]; then
    echo "REFUSING: creds resolve to account '$acct', expected '$ACCOUNT_EXPECTED'." >&2
    echo "Set the right AWS credentials/profile and retry." >&2
    return 1
  fi
  echo "==> account $acct  region $AWS_REGION  cluster $CLUSTER"
}
